# Contentful — Content Delivery API (published content)
# Copy to .env and fill in. Get these from Contentful → Settings → API keys.
CONTENTFUL_SPACE_ID=
CONTENTFUL_CDA_TOKEN=
CONTENTFUL_ENVIRONMENT=master

# Optional — Google Search Console & Analytics (injected at build time)
GOOGLE_SITE_VERIFICATION=
GA_MEASUREMENT_ID=

# Content model (create in Contentful → Content model):
#   blogPost   — slug, title, excerpt, body, coverImage, publishedDate, updatedDate,
#                seoTitle, seoDescription, focusKeyword, canonicalUrl, coverImageAlt,
#                ogTitle, ogDescription, schemaJsonLd, author (ref), category (ref or text),
#                tags (refs), relatedTools (text list)
#   author     — slug, name, bio, avatar, role, seoTitle, seoDescription
#   category   — slug, name, description, seoTitle, seoDescription
#   tag        — slug, name, seoTitle, seoDescription
